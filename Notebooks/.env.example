# Copy this file to `.env` and edit values as needed.
#
# NOTE (Windows paths): either use forward slashes (recommended) or escape backslashes.
# Example: CLASSIFIER_DATASET_PATH=C:/data/my_dataset.csv
#
# Heavy steps are gated so you don't accidentally train when data is missing.
RUN_DAPT=0
RUN_FINETUNE=0
RUN_EVAL=0

# ---------------------------- API keys --------------------------------------
# Never commit real keys. Put real values only in `.env` (this file is a template).
GROQ_API_KEY=
LANGSMITH_API_KEY=

# LangSmith / LangChain tracing (optional)
LANGSMITH_TRACING=false
LANGCHAIN_PROJECT=diagnosis prediction pipeline

# Reproducibility
SEED=27

# Base model
BASE_MODEL_NAME=emilyalsentzer/Bio_ClinicalBERT

# Optional: explicitly set the classifier backbone.
# If not set, the notebook defaults to DAPT_ADAPTED_DIR (and falls back to BASE_MODEL_NAME if missing).
# CLS_MODEL_NAME=./dapt_adapted_model

# ---------------------------- Data paths -------------------------------------
# Colab defaults (change for local runs)
DAPT_DATASET1_PATH=/content/drive/MyDrive/Datasets/dataset1.csv
DAPT_DATASET2_PATH=/content/drive/MyDrive/Datasets/dataset2.csv
DAPT_TEXT_COLUMN=text

CLASSIFIER_DATASET_PATH=/content/drive/MyDrive/Datasets/Final_Augmented_dataset_Diseases_and_Symptoms.csv

# ---------------------------- Output dirs ------------------------------------
DAPT_OUTPUT_DIR=./dapt_model
DAPT_ADAPTED_DIR=./dapt_adapted_model
FINETUNE_OUTPUT_DIR=./hf_disease_classifier
FINAL_MODEL_DIR="/content/drive/MyDrive/fine tuned model & tokenizer/final_model-2"

# ---------------------------- DAPT params ------------------------------------
DAPT_NUM_EPOCHS=3
DAPT_BATCH_SIZE=16
DAPT_LEARNING_RATE=5e-5
DAPT_WEIGHT_DECAY=0.01
DAPT_WARMUP_STEPS=500
DAPT_SAVE_STEPS=500
DAPT_SAVE_TOTAL_LIMIT=2
DAPT_LOGGING_STEPS=100
DAPT_MLM_PROB=0.15
DAPT_MAX_LENGTH=512

# ------------------------- Classifier params ---------------------------------
CLS_MAX_LENGTH=256
CLS_NUM_EPOCHS=4
CLS_BATCH_SIZE=16
CLS_LEARNING_RATE=2e-5
TEST_SIZE=0.10
VALID_SIZE=0.30
RANDOMIZE_SYMPTOM_ORDER=1
